# Required: OpenRouter API key for passport scanning (get one at https://openrouter.ai)
OPENROUTER_API_KEY=

# Optional: Public URL of this app (used for OpenRouter referer header)
PUBLIC_URL=

# Optional: URL of the Playwright service (only needed if using server-side submission)
# PLAYWRIGHT_SERVICE_URL=

# Optional: Shared secret for Playwright service authentication
# PLAYWRIGHT_SERVICE_SECRET=
